# Kopiere diese Datei nach .env und setze einen langen Zufallswert für SECRET_KEY
# Generieren z.B. mit: python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-long-random-string

# Cloudflare Turnstile widget secret (Dashboard → Turnstile → widget → Secret)
# Required for login / register / forgot-password; never commit the real value.
TURNSTILE_SECRET=
